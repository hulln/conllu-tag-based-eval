# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local tool state and temp files
.codex
*.log
*.tmp
*.swp
*.swo

# Testing, linting, and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Notebook checkpoints
.ipynb_checkpoints/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local model/download cache (large, generated)
cache/

# Keep transient rerun outputs local
predictions/reruns/

# Keep supplementary (non-canonical) mode outputs local
predictions/output/supplementary/
results/output/*/supplementary/

# Legacy layout from older versions (local only)
predictions/runs/
results/runs/

# Local SSJ gold dataset files (do not publish in this repository)
data/gold/
data/gold/sl_ssj-ud-test.conllu

# Keep archive and sample/test-run artifacts local
archive/first-run/
archive/local/
archive/local/**
predictions/archive/
results/archive/
data/samples/
predictions/samples/
predictions/output/*sample*/
results/output/*sample*/

# Private run comparison notes (local only)
references/run-comparison-*.md

# Private supervisor/task instruction snapshots (local only)
references/supervisor-instructions-*.txt
references/instructions-task-mail*.txt

# Local reference PDFs (keep links in README instead of committing files)
references/*.pdf

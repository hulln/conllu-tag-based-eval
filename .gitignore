# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local tool state and temp files
.codex
*.log
*.tmp
*.swp
*.swo

# Testing, linting, and type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Notebook checkpoints
.ipynb_checkpoints/

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local model/download cache (large, generated)
cache/

# Keep transient rerun outputs local
predictions/reruns/

# Local gold dataset files (do not publish in this repository)
data/gold/

# Keep archive and sample/test-run artifacts local
archive/first-run/
archive/local/
predictions/archive/
results/archive/
data/samples/
predictions/samples/
predictions/runs/*sample*/
results/runs/*sample*/

# Private run comparison notes (local only)
references/run-comparison-*.md

# Private supervisor/task instruction snapshots (local only)
references/supervisor-instructions-*.txt
references/instructions-task-mail*.txt

# Local reference PDFs (keep links in README instead of committing files)
references/*.pdf
